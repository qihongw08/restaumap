generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id
  username        String?           @map("username")
  email           String?           @map("email")
  avatarUrl       String?           @map("avatar_url")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  userRestaurants UserRestaurant[]
  addedRestaurants GroupRestaurant[] @relation("AddedBy")
  visitAttendees   VisitAttendee[]
  visits           Visit[]

  @@map("users")
}

model Restaurant {
  id                      String            @id @default(uuid())
  name                    String
  address                 String
  formattedAddress        String            @map("formatted_address")
  latitude                Float
  longitude               Float
  googlePlaceId           String            @unique @map("google_place_id")
  openingHoursWeekdayText String[]          @default([]) @map("opening_hours_weekday_text")
  cuisineTypes            String[]          @map("cuisine_types")
  popularDishes           String[]          @map("popular_dishes")
  priceRange              String?           @map("price_range")
  ambianceTags            String[]          @map("ambiance_tags")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  groupRestaurants        GroupRestaurant[]
  imports                 Import[]
  photos                  Photo[]
  userRestaurants         UserRestaurant[]
  visits                  Visit[]

  @@map("restaurants")
}

model UserRestaurant {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  restaurantId    String           @map("restaurant_id")
  status          RestaurantStatus @default(WANT_TO_GO)
  isBlacklisted   Boolean          @default(false) @map("is_blacklisted")
  blacklistReason String?          @map("blacklist_reason")
  blacklistedAt   DateTime?        @map("blacklisted_at")
  savedAt         DateTime         @default(now()) @map("saved_at")
  sourceUrl       String?          @map("source_url")
  sourcePlatform  String?          @map("source_platform")
  rawCaption      String?          @map("raw_caption")
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@map("user_restaurants")
}

model Group {
  id               String            @id @default(uuid())
  name             String
  createdById      String            @map("created_by_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  invites          GroupInvite[]
  members          GroupMember[]
  groupRestaurants GroupRestaurant[]
  shareLinks       ShareLink[]
  visits           Visit[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")
  sortOrder Int      @default(0) @map("sort_order")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupRestaurant {
  id           String     @id @default(uuid())
  groupId      String     @map("group_id")
  restaurantId String     @map("restaurant_id")
  addedById    String     @map("added_by_id")
  addedAt      DateTime   @default(now()) @map("added_at")
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  addedBy      User       @relation("AddedBy", fields: [addedById], references: [id])

  @@unique([groupId, restaurantId])
  @@map("group_restaurants")
}

model GroupInvite {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedById  String?  @map("used_by_id")
  createdAt DateTime @default(now()) @map("created_at")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_invites")
}

model Import {
  id           String     @id @default(uuid())
  sourceUrl    String?    @map("source_url")
  importedAt   DateTime   @default(now()) @map("imported_at")
  restaurantId String     @map("restaurant_id")
  userId       String     @map("user_id")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("imports")
}

model ShareLink {
  id            String        @id @default(uuid())
  token         String        @unique
  type          ShareLinkType
  ownerUserId   String        @map("owner_user_id")
  targetUserId  String?       @map("target_user_id")
  targetGroupId String?       @map("target_group_id")
  expiresAt     DateTime      @map("expires_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  targetGroup   Group?        @relation(fields: [targetGroupId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([targetUserId])
  @@index([targetGroupId])
  @@map("share_links")
}

model Visit {
  id            String          @id @default(uuid())
  restaurantId  String          @map("restaurant_id")
  visitDate     DateTime        @map("visit_date")
  fullnessScore Int             @map("fullness_score")
  tasteScore    Int             @map("taste_score")
  pricePaid     Float           @map("price_paid")
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  userId        String          @map("user_id")
  groupId       String?         @map("group_id")
  photos        Photo[]
  group         Group?          @relation(fields: [groupId], references: [id])
  restaurant    Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id])
  attendees     VisitAttendee[]

  @@map("visits")
}

model VisitAttendee {
  id      String @id @default(uuid())
  visitId String @map("visit_id")
  userId  String @map("user_id")
  visit   Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([visitId, userId])
  @@map("visit_attendees")
}

model Photo {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  url          String
  caption      String?
  uploadedAt   DateTime   @default(now()) @map("uploaded_at")
  userId       String     @map("user_id")
  visitId      String?    @map("visit_id")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  visit        Visit?     @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("photos")
}

enum RestaurantStatus {
  WANT_TO_GO
  VISITED
  FAVORITE
  WARNING_ZONE
}

enum ShareLinkType {
  USER_MAP
  GROUP_MAP
}
